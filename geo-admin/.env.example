POSTGRES_DB=geo_admin
POSTGRES_USER=geo_admin
POSTGRES_PASSWORD=geo_admin_password
# 本地开发使用 localhost；Docker Compose 内 api-server 会自动覆盖为 postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://geo_admin:geo_admin_password@localhost:5432/geo_admin?schema=public
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin123456

API_PORT=3001
# 本地开发留空即可，admin-web 会通过同源 /api 代理到 api-server（避免 CORS）
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_INTERNAL_BASE_URL=http://api-server:3001
# Docker Compose 会自动注入 /app/storage/*；本地开发请保持注释，将使用 api-server/storage/*
# LLMS_STORAGE_DIR=/app/storage/llms
# SITEMAP_STORAGE_DIR=/app/storage/sitemap
PUBLIC_SITE_URL=https://www.yfyk.com
# 逗号分隔的 CORS 白名单：管理后台 + 官网本地 + 正式域名
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,https://www.yfyk.com,https://www.shyfyk.com
